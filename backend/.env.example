# VPS connection
VPS_HOST=your-vps-ip
VPS_USER=root
VPS_PATH=/opt/olho-regional

# Domain for Caddy TLS (e.g. db.yourdomain.com)
DOMAIN=db.yourdomain.com

# Auth: generate Ed25519 keypair (see instructions.md step 4)
# The public key (jwt-public.pem) is mounted into the sqld container.
# The private key (jwt-private.pem) is only used locally to sign tokens.
