# Local dev: no env vars needed — libsql reads ../processamento/database/olho-regional.db directly
#
# Production config:
#   TURSO_DATABASE_URL → set in wrangler.toml [vars]
#   TURSO_AUTH_TOKEN   → add as encrypted Secret in CF Pages dashboard
#
# CI/CD (GitHub Actions secrets):
#   CLOUDFLARE_API_TOKEN
#   CLOUDFLARE_ACCOUNT_ID
#
# TO TEST VPS IN DEV MODE
# VPS_DATABASE_URL=https://olho-regional.lubina.org
# VPS_AUTH_TOKEN=INSERT_HERE